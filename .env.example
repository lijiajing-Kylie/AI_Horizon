# Environment Variables

# AI API Keys (configure at least one)
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx
AZURE_OPENAI_API_KEY=xxx
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
GOOGLE_API_KEY=xxx
MINIMAX_API_KEY=xxx
DASHSCOPE_API_KEY=xxx
DOUBAO_API_KEY=xxx
DEEPSEEK_API_KEY=xxx

# WebHook Url (optional for sending notifications)
HORIZON_WEBHOOK_URL=https://xxx

# GitHub Token (optional but recommended for higher rate limits)
# Without token: 60 requests/hour
# With token: 5000 requests/hour
GITHUB_TOKEN=ghp_xxx

# Apify Token (required for Twitter scraping)
# Get yours at https://console.apify.com/account/integrations
APIFY_TOKEN=apify_api_xxx

# OpenAlex API key (optional for the papers library's OpenAlex source)
# Without a key: anonymous requests share a small daily budget and can be
# throttled with "Insufficient budget" 429s.
# With a key (get one at https://openalex.org/pricing): a much larger daily
# credit budget, checkable at GET https://api.openalex.org/rate-limit?api_key=...
OPENALEX_API_KEY=xxx

# Playwright browser channel (optional; omit to use Playwright's bundled Chromium)
# Set to "chrome" to use system-installed Chrome (macOS: /Applications/Google Chrome.app)
# Useful when the Playwright-managed browser binary is not installed.
# PLAYWRIGHT_CHANNEL=chrome

# horizon-api dev/prod gate (optional; defaults to production i.e. debug disabled)
# Set to "development" locally to unlock GET /api/items/{id}?include_debug=true,
# which attaches full scrape/AI-input diagnostics for the frontend's dev-only
# panel. Has no effect on scraping, scoring, or any other pipeline behavior.
# HORIZON_API_ENV=development
